{
  "name": "@gilvandovieira/thor",
  "version": "0.0.0",
  "description": "Effect-native ORM/database toolkit: fluent schema/query authoring, typed + runtime IR, capability matrix, guards, safe migrations, safe routines.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/gilvandovieira/thor#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gilvandovieira/thor.git",
    "directory": "packages/thor"
  },
  "bugs": {
    "url": "https://github.com/gilvandovieira/thor/issues"
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./sql": {
      "types": "./dist/sql/index.d.ts",
      "default": "./dist/sql/index.js"
    },
    "./postgres": {
      "types": "./dist/postgres/index.d.ts",
      "default": "./dist/postgres/index.js"
    },
    "./sqlite": {
      "types": "./dist/sqlite/index.d.ts",
      "default": "./dist/sqlite/index.js"
    },
    "./mysql": {
      "types": "./dist/mysql/index.d.ts",
      "default": "./dist/mysql/index.js"
    },
    "./migrate": {
      "types": "./dist/migrate/index.d.ts",
      "default": "./dist/migrate/index.js"
    },
    "./testing": {
      "types": "./dist/testing/index.d.ts",
      "default": "./dist/testing/index.js"
    },
    "./routine": {
      "types": "./dist/routine/index.d.ts",
      "default": "./dist/routine/index.js"
    },
    "./relations": {
      "types": "./dist/relations/index.d.ts",
      "default": "./dist/relations/index.js"
    },
    "./capabilities": {
      "types": "./dist/capabilities/index.d.ts",
      "default": "./dist/capabilities/index.js"
    },
    "./observability": {
      "types": "./dist/observability/index.d.ts",
      "default": "./dist/observability/index.js"
    },
    "./introspect": {
      "types": "./dist/introspect/index.d.ts",
      "default": "./dist/introspect/index.js"
    },
    "./skills": {
      "types": "./dist/skills/index.d.ts",
      "default": "./dist/skills/index.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist .tsbuildinfo",
    "prepack": "pnpm run clean && pnpm run build",
    "typecheck": "tsc -b --noEmit",
    "bench": "tsx src/bench/index.ts"
  },
  "peerDependencies": {
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@types/node": "22.19.0",
    "@types/pg": "8.20.0",
    "better-sqlite3": "12.11.1",
    "drizzle-orm": "^0.45.2",
    "effect": "^3.21.0",
    "mysql2": "^3.22.5",
    "pg": "8.22.0",
    "postgres": "3.4.9",
    "prisma": "^7.8.0",
    "tsx": "^4.22.5"
  }
}
